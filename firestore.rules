rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /games/{code} {
      // Read is public — joiner needs to read the room before joining.
      allow read: if true;
      // All writes require Firebase Anonymous Auth. The client SDK
      // (runTransaction) handles auth before touching Firestore.
      allow write: if request.auth != null;
    }
  }
}
