rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /games/{code} {
      // Read is public — joiner needs to read the room before joining.
      allow read: if true;

      // createRoom: any authenticated user may create a new game doc.
      allow create: if request.auth != null;

      // update: the acting user must already be a seated player or host,
      // OR be joining the game (their uid appears in the incoming playerUids
      // but not yet in the existing doc). This blocks arbitrary overwrites
      // by authenticated users who are not part of the game.
      allow update: if request.auth != null && (
        request.auth.uid in resource.data.playerUids ||
        request.auth.uid == resource.data.hostUid ||
        request.auth.uid in request.resource.data.playerUids
      );

      // Games are never deleted — only transitioned to "finished".
      allow delete: if false;
    }
  }
}
