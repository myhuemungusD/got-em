# Got Em — Firebase config (Vite reads `VITE_*` at build time).
#
# Copy this file to `.env` (gitignored) and fill in the values from the
# Firebase console: Project settings -> General -> Your apps -> SDK setup.
#
# NEVER commit `.env` or any of these values. The minimum keys we read are
# apiKey, projectId, and appId — the others come along for the ride.

VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
